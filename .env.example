# Copy this file to .env and fill in your real values.
# .env is gitignored - it will never be committed.

# Get a key from https://console.anthropic.com
# Leave blank/unset to run on the heuristic fallback estimator instead.
ANTHROPIC_API_KEY=

# Optional - defaults to claude-sonnet-5 if unset
# ANTHROPIC_MODEL=claude-sonnet-5

# Optional - only needed if you want a non-default JWT signing secret locally
# JWT_SECRET=
